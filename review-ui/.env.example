# =============================================================================
# review-ui (React + Vite) — environment variables
#
# HOW TO SET UP:
#   1. Copy this file:  cp .env.example .env.develop
#   2. Fill in your local values below
#   3. From the monorepo root run:  pnpm sync-env
#      (or just switch branches — it runs automatically on git checkout)
#
# For staging/production values run `pnpm sync-env` on the test/master branch.
# Those values are fetched automatically from GCP Secret Manager.
# =============================================================================

# ── Backend API ───────────────────────────────────────────────────────────────
# Local:   http://0.0.0.0:50001/api/v1/
# Staging: https://api-staging.nudgenest.io/api/v1/
# Prod:    https://api.nudgenest.io/api/v1/
VITE_APP_BACKEND_HOST=http://0.0.0.0:50001/api/v1/

# ── Review UI public URL ──────────────────────────────────────────────────────
# Local:   http://localhost:3001
# Staging: https://review-staging.nudgenest.io
# Prod:    https://reviews.nudgenest.io
VITE_APP_REVIEW_UI_URL=http://localhost:3001

# ── Demo merchant (used on landing page social proof widget) ──────────────────
VITE_APP_DEMO_MERCHANT_ID=

# ── Monitoring (leave empty to disable Sentry locally) ────────────────────────
VITE_APP_SENTRY_FE_DSN=
