<!-- blocks/business_reviews.liquid -->
{%- liquid
  assign heading = block.settings.heading | default: 'What Our Customers are saying'
  assign reviews_limit = block.settings.reviews_limit | default: 10
  assign show_loading = true
-%}

<div class="business-reviews-container"
     data-reviews-limit="{{ reviews_limit }}"
     data-merchant-id="{{ shop.id }}">
  <!-- Reviews Container -->
  <div class="business-reviews__grid" id="reviewsGrid" >
    <!-- Reviews will be populated here via JavaScript -->
  </div>
</div>

<script>
  {
    (function() {
      'use strict';
      const container = document.querySelector('.business-reviews-container');
      if (!container) return;

      const gridEl = document.getElementById('reviewsGrid');

      // Get configuration from data attributes
      const reviewsLimit = container.dataset.reviewsLimit || 10;
      const merchantId = container.dataset.merchantId;

      // API Configuration - Update with your actual endpoint
      const API_BASE_URL = 'https://nudgenest-backend-1094805904049.europe-west1.run.app/api/v1/';


      async function loadReviews() {
        if (!gridEl) {
          return;
        }

        // Clear any existing content
        gridEl.innerHTML = '';

        const iframeUrl = `https://nudgenest-review-ui-1094805904049.europe-west1.run.app/reviews/${merchantId}`;

        // Create iframe for the review form
        const iframe = document.createElement('iframe');
        iframe.src = iframeUrl;
        iframe.style.cssText = `
          display: block;
          width: 100%;
          min-height: 600px;
          border: none;
          border-radius: 8px;
          background: white;
        `;
        iframe.title = 'List Reviews';
        iframe.allow = 'camera; microphone'; // Allow camera/mic for media uploads

        gridEl.appendChild(iframe);

        // Auto-resize iframe height based on content reported via postMessage
        window.addEventListener('message', function(event) {
          if (event.data && event.data.type === 'nudgenest_resize') {
            iframe.style.height = event.data.height + 'px';
          }
        });

      }
      // Initialize on page load
      loadReviews();
    })()
  }
</script>

<style>
  :root {
    --card-count: {{ reviews_limit }};
  }
  .business-reviews-section {
    width: 100% !important;
    max-width: 100% !important;
  }

  .business-reviews-container {
    width: 100%;
    height: fit-content;
    margin: 0 auto;
  }

  .business-reviews__grid {
    width: 100%;
    height: fit-content;
  }
</style>

{% schema %}
{
  "name": "Business Reviews",
  "target": "section",
  "class": "business-reviews-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "range",
      "id": "reviews_limit",
      "label": "Number of reviews to display",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 10
    }
  ]
}
{% endschema %}
