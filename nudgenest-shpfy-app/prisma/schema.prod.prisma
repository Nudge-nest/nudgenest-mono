// Production Prisma schema — CockroachDB (session storage only)
// Used in Docker builds; replaces schema.prisma at build time.
// Dev keeps SQLite (schema.prisma). Prod uses CockroachDB Serverless.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model BillingCharge {
  id          String    @id
  shop        String
  chargeId    String    @unique
  name        String
  price       Float
  status      String
  test        Boolean   @default(true)
  billingOn   DateTime?
  trialEndsOn DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
