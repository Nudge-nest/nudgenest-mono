# =============================================================================
# nudgenest-shpfy-app (Remix + Shopify) — environment variables template
#
# HOW TO SET UP (one-time per environment):
#   cp .env.example .env.develop     # local dev values
#   cp .env.example .env.staging     # staging values
#   cp .env.example .env.production  # production values
#
# Then fill in the values for each file.
# Switching branches auto-copies the right file to .env:
#   develop / feature / fix  →  .env.develop
#   test                     →  .env.staging
#   master                   →  .env.production
#
# Run manually: pnpm sync-env
#
# NOTE: SHOPIFY_APP_URL changes every time `shopify app dev` restarts
# (Cloudflare tunnel URL). Update .env.develop after each restart.
# =============================================================================

# ── Shopify App Credentials ───────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ── Shopify App Public URL ────────────────────────────────────────────────────
# Dev:     https://<random>.trycloudflare.com  (changes on each `shopify app dev`)
# Staging: https://nudgenest-shopify-1094805904049.europe-west1.run.app
# Prod:    https://merchant.nudgenest.io
# MUST match application_url in shopify.app.toml
SHOPIFY_APP_URL=

# ── Shopify API Scopes ────────────────────────────────────────────────────────
SCOPES=read_products,read_orders,read_customers

# ── Session Storage (CockroachDB / PostgreSQL) ────────────────────────────────
DATABASE_URL=

# ── NudgeNest Backend ─────────────────────────────────────────────────────────
# Local:   http://localhost:50001
# Staging: https://api-staging.nudgenest.io
# Prod:    https://api.nudgenest.io
# No trailing slash
NUDGENEST_BACKEND_URL=http://localhost:50001

# ── Review UI (used in merchant config modal iframe) ─────────────────────────
# Local:   http://localhost:3001
# Staging: https://review-staging.nudgenest.io
# Prod:    https://reviews.nudgenest.io
REVIEW_UI_BASE_URL=http://localhost:3001

NODE_ENV=development
