# Server Configuration
PORT=8080
NODE_ENV=development # development | production (affects email CTA button URLs)

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=nudgenest
# Use the existing pulumi-deploys service account key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/nudgenest-service-account.json

# Google Cloud Storage (for media uploads)
GCS_BUCKET_NAME=nudgenest-media

# For local development with emulator (optional)
# PUBSUB_EMULATOR_HOST=localhost:8085

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# Review UI base URL (used in email links)
# Dev:  http://localhost:3001
# Prod: https://your-review-ui.run.app
REVIEW_UI_BASE_URL=http://localhost:3001

# Shopify Configuration
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_signing_secret

# Database Configuration
DATABASE_URL=your_database_url

# AWS S3 Configuration (for media uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=your_bucket_name

# Twilio Configuration (if using SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Sentry Error Monitoring
# Leave empty to disable Sentry in local dev (no events will be sent)
SENTRY_BACKEND_DSN=

# OLD - No longer needed after Pub/Sub migration
# RABBITMQ_URL_AWS=amqps://username:password@amazon-mq-host:5671
