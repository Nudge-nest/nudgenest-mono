# Server Configuration
PORT=8080
NODE_ENV=development

# Google Cloud Pub/Sub Configuration
GOOGLE_CLOUD_PROJECT_ID=nudgenest
# Use the existing pulumi-deploys service account key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/nudgenest-service-account.json

# For local development with emulator (optional)
# PUBSUB_EMULATOR_HOST=localhost:8085

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key

# Database Configuration
DATABASE_URL=your_database_url

# AWS S3 Configuration (for media uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=your_bucket_name

# Twilio Configuration (if using SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# OLD - No longer needed after Pub/Sub migration
# RABBITMQ_URL_AWS=amqps://username:password@amazon-mq-host:5671
