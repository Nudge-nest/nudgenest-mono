# =============================================================================
# nudgenest (Hapi.js backend) — environment variables template
#
# HOW TO SET UP (one-time per environment):
#   cp .env.example .env.develop     # local dev values
#   cp .env.example .env.staging     # staging values
#   cp .env.example .env.production  # production values
#
# Then fill in the values for each file.
# Switching branches auto-copies the right file to .env:
#   develop / feature / fix  →  .env.develop
#   test                     →  .env.staging
#   master                   →  .env.production
#
# Run manually: pnpm sync-env
# =============================================================================

PORT=50001
NODE_ENV=development

# ── Database (MongoDB) ────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/nudgenestdb
# Staging: mongodb+srv://...
DATABASE_URL=

# ── Resend Email ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_API_SECRET=

# ── Review UI ─────────────────────────────────────────────────────────────────
# Local:   http://localhost:3001
# Staging: https://review-staging.nudgenest.io
# Prod:    https://reviews.nudgenest.io
REVIEW_UI_BASE_URL=http://localhost:3001

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=nudgenest
GCS_BUCKET_NAME=nudgenest-media
GOOGLE_APPLICATION_CREDENTIALS=nudgenest-service-account.json

# ── Pub/Sub ───────────────────────────────────────────────────────────────────
PUBSUB_SUBSCRIPTION_NAME=nudgenest-messaging-pull

# ── Monitoring (leave empty to disable Sentry locally) ────────────────────────
SENTRY_BACKEND_DSN=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
