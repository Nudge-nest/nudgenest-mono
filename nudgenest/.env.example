# =============================================================================
# nudgenest (Hapi.js backend) — environment variables
#
# HOW TO SET UP:
#   1. Copy this file:  cp .env.example .env.develop
#   2. Fill in your local values below
#   3. From the monorepo root run:  pnpm sync-env
#      (or just switch branches — it runs automatically on git checkout)
#
# For staging/production values run `pnpm sync-env` on the test/master branch.
# Those values are fetched automatically from GCP Secret Manager.
# =============================================================================

PORT=50001
NODE_ENV=development

# ── Database (MongoDB) ────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/nudgenestdb
# Staging: fetched from Secret Manager (DATABASE_URL)
DATABASE_URL=

# ── Resend Email ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_API_SECRET=

# ── Review UI ─────────────────────────────────────────────────────────────────
# Local:   http://localhost:3001
# Staging: https://review-staging.nudgenest.io
# Prod:    https://reviews.nudgenest.io
REVIEW_UI_BASE_URL=http://localhost:3001

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=nudgenest
GCS_BUCKET_NAME=nudgenest-media
# Path to your service account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=nudgenest-service-account.json

# ── Pub/Sub ───────────────────────────────────────────────────────────────────
PUBSUB_SUBSCRIPTION_NAME=nudgenest-messaging-pull

# ── Monitoring (leave empty to disable Sentry locally) ────────────────────────
SENTRY_BACKEND_DSN=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
