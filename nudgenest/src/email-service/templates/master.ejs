<!-- templates/master.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= subject %></title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
            background-color: #f5f5f5;
        }
        .wrapper {
            max-width: 600px;
            margin: 20px auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .content {
            padding: 40px 30px;
        }
        .greeting {
            font-size: 16px;
            color: #333;
            margin-bottom: 20px;
        }
        .message {
            font-size: 15px;
            color: #666;
            line-height: 1.6;
            margin-bottom: 30px;
        }
        .product-card {
            background: #f9f9f9;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            text-align: center;
        }
        .product-image {
            width: 200px;
            height: 200px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 15px;
        }
        .star-rating {
            margin: 15px 0;
        }
        .star {
            display: inline-block;
            font-size: 24px;
            color: #FFC107;
            text-decoration: none;
            margin: 0 2px;
        }
        .action-buttons {
            margin-top: 20px;
        }
        .action-buttons a {
            margin: 0 10px;
            color: #666;
            text-decoration: none;
        }
        .action-buttons a:hover {
            text-decoration: underline;
        }
        .cta-button {
            display: inline-block;
            background: #e24861;
            color: white;
            padding: 14px 40px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            margin: 20px 0;
        }
        .incentive-box {
            background: linear-gradient(135deg, #e24861 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 8px;
            margin: 20px 0;
            text-align: center;
        }
        .footer {
            background: #f9f9f9;
            padding: 30px;
            text-align: center;
            border-top: 1px solid #eee;
            border-radius: 0 0 12px 12px;
            font-size: 12px;
            color: #999;
        }
        .footer a {
            color: #666;
            text-decoration: none;
            margin: 0 10px;
        }
    </style>
</head>
<body>
<div class="wrapper">
    <div class="content">
        <!-- Greeting -->
        <div class="greeting">
            Hello <%= typeof userName !== 'undefined' ? userName : 'there' %>,
        </div>

        <!-- Main Message -->
        <div class="message">
            <%- mainMessage %>
        </div>

        <!-- Incentive Box -->
        <% if (typeof incentive !== 'undefined' && incentive) { %>
            <div class="incentive-box">
                <h3><%= incentive.title %></h3>
                <p><%= incentive.description %></p>
            </div>
        <% } %>

        <!-- Products Section -->
        <% if (typeof showItems !== 'undefined' && showItems && typeof formattedItems !== 'undefined' && formattedItems.length > 0) { %>
            <% for (var i = 0; i < formattedItems.length; i++) { %>
                <% var item = formattedItems[i]; %>
                <div class="product-card">
                    <% if (item.imageUrl) { %>
                        <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="product-image">
                    <% } %>
                    <h3><%= item.name %></h3>
                    <% if (item.formattedPrice) { %>
                        <p><%= currency %><%= item.formattedPrice %></p>
                    <% } %>

                    <% if (typeof showRating !== 'undefined' && showRating) { %>
                        <div class="star-rating">
                            <% for (var j = 1; j <= 5; j++) { %>
                                <a href="<%= reviewBaseUrl %>/review/<%= reviewId %>" class="star">⭐</a>
                            <% } %>
                        </div>
                        <div class="action-buttons">
                            <a href="<%= reviewBaseUrl %>/review/<%= reviewId %>">Dislike it</a>
                            <a href="<%= reviewBaseUrl %>/review/<%= reviewId %>" style="font-weight: bold;">Love it!</a>
                        </div>
                    <% } %>
                </div>
            <% } %>
        <% } %>

        <!-- CTA Button -->
        <% if (typeof ctaButton !== 'undefined' && ctaButton) { %>
            <div style="text-align: center; color:#fff">
                <a href="<%= ctaButton.link %>" class="cta-button">
                    <%= ctaButton.text %>
                </a>
            </div>
        <% } %>

        <!-- Secondary Buttons -->
        <% if (typeof secondaryButtons !== 'undefined' && secondaryButtons && secondaryButtons.length > 0) { %>
            <div style="text-align: center; margin: 20px 0;">
                <% for (var k = 0; k < secondaryButtons.length; k++) { %>
                    <% var button = secondaryButtons[k]; %>
                    <a href="<%= button.link %>" style="margin: 0 10px; color: #e24861;">
                        <%= button.text %>
                    </a>
                <% } %>
            </div>
        <% } %>

        <!-- Additional Message -->
        <% if (typeof additionalMessage !== 'undefined' && additionalMessage) { %>
            <div class="message">
                <%- additionalMessage %>
            </div>
        <% } %>
    </div>

    <!-- Footer -->
    <div class="footer">
        <% if (typeof order_number === 'undefined') { %>
            <p></p>
        <% } %>
        <% if (order_number && typeof order_number !== 'undefined') { %>
            <p>Order #<%= order_number %></p>
        <% } %>
        <p>© <%= currentYear %>  Powered by Nudge-nest </p>
        <div>

        </div>
    </div>
</div>
</body>
</html>