{
    "name": "nudgenest-event-bus",
    "version": "1.0.0",
    "description": "event bus for nudgenest",
    "main": "build/server.js",
    "author": "Olujuwon Alabi",
    "license": "MIT",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:unit": "jest src/__tests__/core",
        "test:integration": "jest src/__tests__/integration",
        "test:ci": "jest --ci --coverage --maxWorkers=2",
        "ngrok": "ngrok http 50001",
        "build": "tsc -p tsconfig.json",
        "start": "node build/server.js",
        "start-dev": "tsc -w & nodemon build/server.js",
        "dev": "npm-run-all -p start-dev",
        "format": "prettier --write .",
        "db-g": "npx prisma generate",
        "db-p": "npx prisma db push",
        "lint": "eslint .",
        "migrate:qr-urls": "tsc scripts/updateQrCodeUrls.ts --outDir build/scripts && node build/scripts/updateQrCodeUrls.js"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.940.0",
        "@aws-sdk/s3-request-presigner": "^3.940.0",
        "@google-cloud/pubsub": "^4.10.0",
        "@google-cloud/storage": "^7.18.0",
        "@hapi/boom": "^10.0.1",
        "@hapi/hapi": "^21.4.4",
        "@hapi/inert": "^7.1.0",
        "@prisma/client": "^6.19.0",
        "@sendgrid/mail": "^8.1.6",
        "busboy": "^1.6.0",
        "dotenv": "^16.6.1",
        "ejs": "^3.1.10",
        "hapi-alive": "^2.0.4",
        "hapi-pino": "^12.1.0",
        "joi": "^18.0.2",
        "jsonschema": "^1.5.0",
        "nodemailer": "^6.10.1",
        "resend": "^6.9.1",
        "ts-node": "^10.9.2",
        "twilio": "^5.10.6",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@hapi/shot": "^6.0.2",
        "@jest/globals": "^30.2.0",
        "@types/busboy": "^1.5.4",
        "@types/ejs": "^3.1.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.19.1",
        "@types/nodemailer": "^6.4.21",
        "aws-sdk-client-mock": "^4.1.0",
        "eslint": "^9.39.1",
        "globals": "^15.15.0",
        "jest": "^30.2.0",
        "jest-mock-extended": "^4.0.0",
        "nodemon": "^3.1.11",
        "npm-run-all": "^4.1.5",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.7.3",
        "prisma": "^6.19.0",
        "ts-jest": "^29.4.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.0"
    }
}
